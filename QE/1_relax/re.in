&control
    calculation = 'relax'
    prefix = 'graphene'
    pseudo_dir = '../pseudo/'
    outdir = './tmp/'
    tstress = .true.
    forc_conv_thr = 1.0d-8
/
&system
    ibrav = 0, nat = 2, ntyp = 1,
    ecutwfc = 50.0,
    occupations = 'smearing', smearing = 'gaussian', degauss = 0.01
/
&electrons
    conv_thr = 1.0d-8
/
&ions
    ion_dynamics = 'damp'
/
