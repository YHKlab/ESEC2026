&control
    calculation = 'vc-relax'
    prefix = 'graphene'
    pseudo_dir = '../pseudo/'
    outdir = './tmp/'
    tstress = .true.
    forc_conv_thr = 1.0d-8
/
&system
    ibrav = 0, nat = 2, ntyp = 1,
    ecutwfc = 50.0,
    occupations = 'smearing', smearing = 'gaussian', degauss = 0.01,
    nosym = .true.
/
&electrons
    conv_thr = 1.0d-8
/
&ions
    ion_dynamics = 'damp'
/
&cell
    press_conv_thr=0.1
    cell_dofree = 'xy'
/
ATOMIC_SPECIES
  C  12.011  C_ONCV_PBE_sr.upf
CELL_PARAMETERS (angstrom)
   2.40000   0.00000   0.00000
  -1.20000   2.10000   0.00000
   0.00000   0.00000  10.00000
ATOMIC_POSITIONS (crystal)
  C  0.000000  0.000000  0.000000
  C  0.333333  0.666667  0.000000
K_POINTS {automatic}
  9 9 1 0 0 0
